APP_ENV=local
APP_NAME=Stock AI MVP
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://stock:stock@postgres:5432/stock_ai
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000
DEFAULT_USER_ID=local-demo-user
AUTH_MODE=local
AUTH_USER_ID_CLAIM=sub
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_AUDIENCE=
AUTH_JWT_ISSUER=
AUTH_JWT_JWKS_URL=
AUTH_JWT_SECRET=
AUTH_JWT_SECRET_NAME=
MARKET_DATA_PROVIDER=mock
NEWS_PROVIDER=mock
POLYGON_BASE_URL=https://api.polygon.io
PROVIDER_TIMEOUT_SECONDS=10
PROVIDER_CACHE_TTL_SECONDS=30
PROVIDER_RETRY_COUNT=2
SECRET_PROVIDER=env
SECRETS_DIR=/run/secrets
OPENAI_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
OPENAI_API_KEY_SECRET_NAME=
POLYGON_API_KEY_SECRET_NAME=
FINNHUB_API_KEY_SECRET_NAME=
ALPHAVANTAGE_API_KEY_SECRET_NAME=
